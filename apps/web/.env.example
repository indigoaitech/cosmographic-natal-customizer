EPHEMERIS_API_URL=http://localhost:8000

# Public origin for absolute print asset URLs (session handoff)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cosmographic Shopify — public brand domain
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=www.cosmographic.store
# Internal shop host for Storefront GraphQL (required)
SHOPIFY_SHOP_DOMAIN=wtx6n6-gu.myshopify.com

# Personalized catalog redirect (Create My Personalized Products)
SHOPIFY_PERSONALIZED_COLLECTION_HANDLE=personalized
# SHOPIFY_PERSONALIZED_COLLECTION_URL=https://www.cosmographic.store/collections/personalized

# Multi-SKU variants (preferred). Falls back to SHOPIFY_PRODUCT_VARIANT_ID for apparel.
SHOPIFY_VARIANT_TEE=
SHOPIFY_VARIANT_HOODIE=
SHOPIFY_VARIANT_CREW=
SHOPIFY_VARIANT_POSTER=

# From Shopify Admin → Develop apps → Storefront API token
SHOPIFY_STOREFRONT_TOKEN=
# Optional Headless private token (server-side)
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=
# Legacy single variant (used if SHOPIFY_VARIANT_* unset)
SHOPIFY_PRODUCT_VARIANT_ID=
SHOPIFY_API_VERSION=2025-01

# Orders/create webhook secret
SHOPIFY_WEBHOOK_SECRET=

# CORS for session API (comma-separated origins). Defaults include store + localhost.
# CORS_ALLOWED_ORIGINS=https://www.cosmographic.store,https://wtx6n6-gu.myshopify.com

# Bearer token required for GET /api/session/:id?format=full
# SESSION_API_TOKEN=

# Set to 1 only if fulfillment needs full chart JSON on disk (default: omit snapshot)
# SESSION_STORE_CHART_SNAPSHOT=0

RESEND_API_KEY=
EMAIL_DRY_RUN=true

# Optional durable asset storage (defaults to local FS under apps/web/data)
# DESIGN_STORAGE_PATH=
# SESSION_STORAGE_PATH=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Printify API (fulfillment automation — stubbed until set)
# PRINTIFY_API_TOKEN=
# PRINTIFY_SHOP_ID=

# Optional analytics beacon
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=
